# ═══════════════════════════════════════════════════════════════════════
#  HOMEPAGE .gitignore
# ═══════════════════════════════════════════════════════════════════════
#
#  WHY THIS FILE EXISTS
#  ────────────────────
#  Git tracks every file it can see.  Without a .gitignore, it will
#  happily commit thousands of library files, your private secrets,
#  your database, and multi-gigabyte build artifacts.  This file tells
#  Git "pretend these don't exist."
#
#  Rule of thumb:  if a file is *generated*, *downloaded*, *personal*,
#  or *secret*, it does not belong in version control.
# ═══════════════════════════════════════════════════════════════════════


# ── Python ────────────────────────────────────────────────────────────
#  Virtual environments contain thousands of third-party library files
#  that anyone can recreate with `pip install -r requirements.txt`.
#  __pycache__ and *.pyc are compiled bytecode — Python regenerates
#  them automatically every time you run the code.
venv/
.venv/
.venv-client/
.venv-server-build/
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg


# ── Node.js ───────────────────────────────────────────────────────────
#  node_modules/ can contain tens of thousands of files.  Anyone can
#  recreate it with `npm install` using the package.json that IS tracked.
#  package-lock.json is a snapshot of exact dependency versions — it's
#  fine to track (many projects do), but for this project the Electron
#  client is built separately so we skip it.
node_modules/


# ── Secrets & Environment ─────────────────────────────────────────────
#  .env contains passwords, API keys, and secret keys.  If this gets
#  pushed to GitHub, anyone on the internet can see your credentials.
#  NEVER commit secrets.  Ever.
.env
data/.secret_key
data/runtime_secure_mode.env
hf_cookies.txt


# ── Database ──────────────────────────────────────────────────────────
#  SQLite databases are binary files that change every time the server
#  runs.  They contain your personal data (users, posts, messages) and
#  should not be shared.  A fresh database is created automatically
#  when the server starts.
*.db


# ── Build Artifacts ───────────────────────────────────────────────────
#  build/ and dist/ contain compiled .exe files, AppImages, and other
#  binary output from PyInstaller.  They can be hundreds of megabytes
#  and are regenerated by the build scripts.
build/
dist/
tmp/
*.spec.bak


# ── User Data & Uploads ──────────────────────────────────────────────
#  media/ holds user-uploaded images.  external data/ can hold the
#  Wikipedia offline dump (~22 GB).  These are personal content, not
#  source code.
media/
external data/


# ── Runtime Data ──────────────────────────────────────────────────────
#  These directories are created at runtime by Caddy, the forum DB,
#  generated crosswords, etc.  They're ephemeral data, not source.
data/caddy-config/
data/caddy-data/
data/mybb-db/
data/crosswords/
data/server_id.txt


# ── Logs ──────────────────────────────────────────────────────────────
#  Log files grow continuously and contain runtime output.  They have
#  zero value in version control and just create noise in diffs.
*.log


# ── IDE & OS Files ────────────────────────────────────────────────────
#  Your editor and operating system create hidden config/cache files.
#  These are specific to YOUR machine and shouldn't affect anyone else.
.vscode/
.idea/
*.swp
*.swo
*~
Thumbs.db
Desktop.ini
.DS_Store


# ── Caches ────────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/


# ── Misc Artifacts ────────────────────────────────────────────────────
#  127.0.0.1 is a stray file (likely a curl/wget artifact).
#  _run_server_capture logs are debug/dev artifacts.
127.0.0.1
_run_server_capture*.log
