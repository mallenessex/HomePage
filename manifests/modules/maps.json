{
  "name": "maps",
  "version": "1",
  "runtime": "podman-compose",
  "compose_file": "podman-compose.yml",
  "services": [],
  "routes": [
    {
      "module_path": "/maps/",
      "upstream": "http://localhost:8001/maps/"
    }
  ],
  "healthcheck": {
    "url": "http://localhost:8001/maps/api/status",
    "timeout_seconds": 10
  },
  "install_policy": "manual"
}
